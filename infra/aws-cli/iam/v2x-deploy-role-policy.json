{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnlyNamedV2xHttpApi",
      "Effect": "Allow",
      "Action": "apigateway:GET",
      "Resource": [
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/*"
      ]
    },
    {
      "Sid": "ReconcileNamedV2xHttpApiChildren",
      "Effect": "Allow",
      "Action": [
        "apigateway:POST",
        "apigateway:PATCH"
      ],
      "Resource": [
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/integrations",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/integrations/*",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/routes",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/routes/*",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/stages",
        "arn:aws:apigateway:us-west-1::/apis/w0j9m7dgpg/stages/*"
      ]
    },
    {
      "Sid": "ReadAndUpdateExistingV2xReadLambda",
      "Effect": "Allow",
      "Action": [
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:GetPolicy",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:AddPermission",
        "lambda:RemovePermission"
      ],
      "Resource": "arn:aws:lambda:us-west-1:147229569658:function:v2x-backend-read"
    }
  ]
}
