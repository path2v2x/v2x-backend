# Install as /etc/v2x-drive-link-health.env only after GET /drive-config and
# versioned S3 publication have passed their deployment gates.
DRIVE_LINK_HEALTH_REPAIR=true

# Quick Tunnel mode derives its current URL from LOG_FILE in
# /etc/v2x-drive-tunnel.env. Named mode derives wss://$PUBLIC_HOSTNAME from that
# same file. Set this only when an explicit endpoint must override either mode.
# DRIVE_WS_URL=wss://drive.path2v2x.net
